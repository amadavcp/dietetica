    <div class="card-body">
      <table>
        <thead>
          <tr>
            <th style="width:40%">Código / Nombre</th>
            <th style="width:55%">Importe</th>
            <th style="width:5%"></th>
          </tr>
        </thead>
        <tbody id="tbody2"></tbody>
        <tfoot>
          <tr class="total-row">
