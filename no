<!-- Firebase -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getDatabase, ref, set, get, push, onValue, remove } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

  const firebaseConfig = {
    apiKey: "AIzaSyDvqDq1CqtQhboBvJepY1fFAKhuFai-uRw",
    authDomain: "descuentos-grotas.firebaseapp.com",
    databaseURL: "https://descuentos-grotas-default-rtdb.firebaseio.com",
    projectId: "descuentos-grotas",
    storageBucket: "descuentos-grotas.firebasestorage.app",
    messagingSenderId: "595432117930",
    appId: "1:595432117930:web:8c45f111cb3516ec0da2d3"
  };

  let db;
  let historialGlobal = [];

  try {
    const app = initializeApp(firebaseConfig);
    db = getDatabase(app);
    window._db = db;
    window._dbRef = ref;
    window._dbSet = set;
    window._dbGet = get;
    window._dbPush = push;
    window._dbOnValue = onValue;
    window._firebaseOk = true;
  } catch(e) {
    window._firebaseOk = false;
    console.warn("Firebase no configurado, modo local");
  }

  window._initHistorial = function() {
    if (!window._firebaseOk) {
      cargarLocal();
      return;
    }
    const histRef = ref(db, 'historial');
    onValue(histRef, (snapshot) => {
      const data = snapshot.val();
      // Guardar con la key de Firebase para poder borrar
      historialGlobal = data ? Object.entries(data).map(([k, v]) => ({ ...v, _fbKey: k })) : [];
      window._historial = historialGlobal;
      renderHistorial(historialGlobal);
    });
  };

  window._guardarSemana = async function(semana) {
    if (!window._firebaseOk) {
      guardarLocal(semana);
      return;
    }
    const histRef = ref(db, 'historial');
    const newRef = push(histRef);
    await set(newRef, semana);
  };

  window._borrarSemanaFirebase = async function(fbKey) {
    const itemRef = ref(db, 'historial/' + fbKey);
    await remove(itemRef);
  };
</script>

<style>
