<div class="toast" id="toast"></div>

<script>
// ========== ESTADO ==========
let rows1 = []; // [{id, codigo, descripcion, importe}]
let rows2 = []; // [{id, codigo, importe, fixed}]

const FIXED_CLIENTES = ['s61ma', 's5mi', 's23ju'];

// ========== INIT ==========
window.addEventListener('load', () => {
  setMondayDate();
  initRows1();
  initRows2();
  setTimeout(() => {
    if (window._initHistorial) {
      window._initHistorial();
    } else {
      cargarLocal();
    }
    updateStatus();
  }, 1000);
});

function setMondayDate() {
  const today = new Date();
  const day = today.getDay();
  const diff = day === 0 ? -6 : 1 - day;
  const monday = new Date(today);
  monday.setDate(today.getDate() + diff);
  document.getElementById('fechaSemana').value = monday.toISOString().split('T')[0];
}

function updateStatus() {
  const dot = document.getElementById('statusDot');
  const txt = document.getElementById('statusText');
  if (window._firebaseOk) {
    dot.className = 'status-dot online';
    txt.textContent = 'Sincronizado en la nube';
    document.getElementById('firebaseNotice').style.display = 'none';
  } else {
    dot.className = 'status-dot';
    txt.textContent = 'Solo local (sin nube)';
  }
}

// ========== TABLA 1 ==========
function initRows1() {
  rows1 = [{ id: Date.now(), codigo: '', descripcion: 'galletas rotas', importe: '' }];
  renderTable1();
}

function addRow1() {
  rows1.push({ id: Date.now(), codigo: '', descripcion: 'galletas rotas', importe: '' });
  renderTable1();
}

function removeRow1(id) {
  rows1 = rows1.filter(r => r.id !== id);
  renderTable1();
  recalc();
}

function renderTable1() {
  const tbody = document.getElementById('tbody1');
  tbody.innerHTML = '';
  rows1.forEach(row => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><input class="cell" placeholder="Código/Nombre" value="${row.codigo}" oninput="updateRow1(${row.id},'codigo',this.value)"></td>
      <td><input class="cell" placeholder="galletas rotas" value="${row.descripcion}" oninput="updateRow1(${row.id},'descripcion',this.value)"></td>
      <td><input class="cell monto" placeholder="0" value="${row.importe}" oninput="updateRow1(${row.id},'importe',this.value)" type="number"></td>
      <td><button class="btn-del" onclick="removeRow1(${row.id})">✕</button></td>
    `;
    tbody.appendChild(tr);
  });
  recalc();
}

function updateRow1(id, field, value) {
  const r = rows1.find(r => r.id === id);
  if (r) r[field] = value;
  recalc();
}

// ========== TABLA 2 ==========
function initRows2() {
  rows2 = FIXED_CLIENTES.map(c => ({ id: c, codigo: c, importe: '', fixed: true }));
  renderTable2();
}

function addRow2() {
  rows2.push({ id: 'extra_' + Date.now(), codigo: '', importe: '', fixed: false });
  renderTable2();
}

function removeRow2(id) {
  const r = rows2.find(r => r.id === id);
  if (r && r.fixed) { showToast('No se puede eliminar un cliente fijo', true); return; }
  rows2 = rows2.filter(r => r.id !== id);
  renderTable2();
  recalc();
}

function renderTable2() {
  const tbody = document.getElementById('tbody2');
  tbody.innerHTML = '';
  rows2.forEach(row => {
    const tr = document.createElement('tr');
    const nameInput = row.fixed
      ? `<input class="cell fixed-name" value="${row.codigo}" readonly style="color:var(--verde);font-weight:700;">`
      : `<input class="cell" placeholder="Código/Nombre" value="${row.codigo}" oninput="updateRow2('${row.id}','codigo',this.value)">`;
    tr.innerHTML = `
      <td>${nameInput}</td>
      <td><input class="cell monto" placeholder="0" value="${row.importe}" oninput="updateRow2('${row.id}','importe',this.value)" type="number"></td>
      <td>${row.fixed ? '' : `<button class="btn-del" onclick="removeRow2('${row.id}')">✕</button>`}</td>
    `;
    tbody.appendChild(tr);
  });
  recalc();
}

function updateRow2(id, field, value) {
  const r = rows2.find(r => r.id === id);
  if (r) r[field] = value;
  recalc();
}

// ========== CALCULOS ==========
function recalc() {
  const t1 = rows1.reduce((s, r) => s + (parseFloat(r.importe) || 0), 0);
  const t2 = rows2.reduce((s, r) => s + (parseFloat(r.importe) || 0), 0);
  const total = t1 + t2;

  document.getElementById('total1').textContent = formatMoney(t1);
  document.getElementById('total1Badge').textContent = formatMoney(t1);
  document.getElementById('total2').textContent = formatMoney(t2);
  document.getElementById('total2Badge').textContent = formatMoney(t2);
  document.getElementById('totalSemanal').textContent = formatMoney(total);
}

function formatMoney(n) {
  return '$' + n.toLocaleString('es-AR');
}

// ========== GUARDAR ==========
function guardarSemana() {
  const fecha = document.getElementById('fechaSemana').value;
  if (!fecha) { showToast('Seleccioná la fecha primero', true); return; }

  const t1 = rows1.reduce((s, r) => s + (parseFloat(r.importe) || 0), 0);
  const t2 = rows2.reduce((s, r) => s + (parseFloat(r.importe) || 0), 0);

  const semana = {
    fecha,
    dieteticas: rows1.map(r => ({ codigo: r.codigo, descripcion: r.descripcion, importe: parseFloat(r.importe) || 0 })),
    clientes: rows2.map(r => ({ codigo: r.codigo, importe: parseFloat(r.importe) || 0 })),
    total1: t1,
    total2: t2,
    totalSemanal: t1 + t2,
    guardadoEn: new Date().toISOString()
  };

  if (window._firebaseOk && window._guardarSemana) {
    window._guardarSemana(semana).then(() => showToast('✅ Semana guardada en la nube')).catch(() => showToast('Error al guardar', true));
  } else {
    guardarLocal(semana);
    showToast('✅ Semana guardada');
  }
}

function guardarLocal(semana) {
  const hist = JSON.parse(localStorage.getItem('historial_dietetica') || '[]');
  hist.unshift(semana);
  localStorage.setItem('historial_dietetica', JSON.stringify(hist));
  renderHistorial(hist);
}

function cargarLocal() {
  const hist = JSON.parse(localStorage.getItem('historial_dietetica') || '[]');
  window._historial = hist;
  renderHistorial(hist);
}

// ========== HISTORIAL ==========
function toggleHistorial() {
  const body = document.getElementById('historialBody');
  const icon = document.getElementById('histToggle');
  body.classList.toggle('visible');
  icon.classList.toggle('open');
}

function renderHistorial(lista) {
  const cont = document.getElementById('historialContent');
  if (!lista || lista.length === 0) {
    cont.innerHTML = '<p style="color:#888;text-align:center;padding:20px;font-size:0.85rem;">No hay semanas guardadas aún.</p>';
    return;
  }

  const sorted = [...lista].sort((a, b) => b.fecha.localeCompare(a.fecha));
  // Guardar referencia global con key para acceder desde botones
  window._sortedHist = sorted;

  cont.innerHTML = sorted.map((s, i) => {
    const key = s._fbKey || s.guardadoEn || i;
    return `
    <div class="semana-item">
      <div class="semana-item-header" onclick="toggleDetalle('det_${i}')">
        <span class="fecha-label">📅 ${formatFecha(s.fecha)}</span>
        <span class="total-badge">${formatMoney(s.totalSemanal || 0)}</span>
      </div>
      <div class="semana-detalle" id="det_${i}">
        <strong style="color:var(--verde);font-size:0.8rem;">↩️ DEVOLUCIONES</strong>
        <table style="margin:6px 0 10px;">
          <thead><tr><th>Código</th><th>Descripción</th><th style="text-align:right">Importe</th></tr></thead>
          <tbody>
            ${(s.dieteticas||[]).map(d => `<tr><td>${d.codigo||'-'}</td><td>${d.descripcion||'-'}</td><td style="text-align:right;font-family:monospace">${formatMoney(d.importe)}</td></tr>`).join('')}
          </tbody>
          <tfoot><tr><td colspan="2" style="font-weight:700">Total</td><td style="text-align:right;font-weight:700;font-family:monospace">${formatMoney(s.total1)}</td></tr></tfoot>
        </table>
        <strong style="color:var(--verde);font-size:0.8rem;">🏷️ DESCUENTOS</strong>
        <table style="margin:6px 0;">
          <thead><tr><th>Código</th><th style="text-align:right">Importe</th></tr></thead>
          <tbody>
            ${(s.clientes||[]).map(c => `<tr><td>${c.codigo||'-'}</td><td style="text-align:right;font-family:monospace">${formatMoney(c.importe)}</td></tr>`).join('')}
          </tbody>
          <tfoot><tr><td style="font-weight:700">Total</td><td style="text-align:right;font-weight:700;font-family:monospace">${formatMoney(s.total2)}</td></tr></tfoot>
        </table>
        <div style="background:var(--verde);color:white;border-radius:6px;padding:6px 12px;display:flex;justify-content:space-between;margin-top:6px;">
          <strong>TOTAL SEMANAL</strong>
          <strong style="font-family:monospace">${formatMoney(s.totalSemanal)}</strong>
        </div>
        <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;">
          <button onclick="exportarSemanaSola(${i})" style="flex:1;min-width:80px;background:#217346;color:white;border:none;border-radius:6px;padding:8px 10px;font-size:0.8rem;cursor:pointer;font-family:'Sora',sans-serif;">📊 Excel</button>
          <button onclick="abrirEditar(${i})" style="flex:1;min-width:80px;background:#2980b9;color:white;border:none;border-radius:6px;padding:8px 10px;font-size:0.8rem;cursor:pointer;font-family:'Sora',sans-serif;">✏️ Editar</button>
          <button onclick="confirmarBorrar(${i})" style="flex:1;min-width:80px;background:#e74c3c;color:white;border:none;border-radius:6px;padding:8px 10px;font-size:0.8rem;cursor:pointer;font-family:'Sora',sans-serif;">🗑️ Borrar</button>
        </div>
      </div>
    </div>
  `}).join('');
}

function toggleDetalle(id) {
  document.getElementById(id).classList.toggle('visible');
}

function formatFecha(f) {
  if (!f) return '-';
  const [y,m,d] = f.split('-');
  return `${d}/${m}/${y}`;
}

// ========== EXCEL ==========
function descargarExcel() {
  const hist = window._historial || JSON.parse(localStorage.getItem('historial_dietetica') || '[]');
  const wb = XLSX.utils.book_new();

  // Hoja resumen
  const resumenData = [['Fecha', 'Total Dietéticas', 'Total Clientes', 'Total Semanal']];
  const sorted = [...hist].sort((a,b) => a.fecha.localeCompare(b.fecha));
  sorted.forEach(s => {
    resumenData.push([formatFecha(s.fecha), s.total1 || 0, s.total2 || 0, s.totalSemanal || 0]);
  });
  const wsResumen = XLSX.utils.aoa_to_sheet(resumenData);
  XLSX.utils.book_append_sheet(wb, wsResumen, 'Resumen');

  // Hoja detalle dietéticas
  const det1 = [['Semana', 'Código', 'Descripción', 'Importe']];
  sorted.forEach(s => {
    (s.dieteticas||[]).forEach(d => det1.push([formatFecha(s.fecha), d.codigo, d.descripcion, d.importe]));
    det1.push([formatFecha(s.fecha), '', 'SUBTOTAL', s.total1]);
    det1.push([]);
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(det1), 'Dietéticas');

  // Hoja detalle clientes
  const det2 = [['Semana', 'Código/Nombre', 'Importe']];
  sorted.forEach(s => {
    (s.clientes||[]).forEach(c => det2.push([formatFecha(s.fecha), c.codigo, c.importe]));
    det2.push([formatFecha(s.fecha), 'SUBTOTAL', s.total2]);
    det2.push([]);
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(det2), 'Clientes');

  XLSX.writeFile(wb, `dietetica_${new Date().toISOString().split('T')[0]}.xlsx`);
  showToast('📊 Excel descargado');
}

function exportarSemanaSola(idx) {
  const sorted = window._sortedHist;
  if (!sorted || !sorted[idx]) { showToast('Error al exportar', true); return; }
  const s = sorted[idx];

  const wb = XLSX.utils.book_new();
  const data = [
    [`Semana del: ${formatFecha(s.fecha)}`],
    [],
    ['DEVOLUCIONES'],
    ['Código', 'Descripción', 'Importe'],
    ...(s.dieteticas||[]).map(d => [d.codigo, d.descripcion, d.importe]),
    ['', 'TOTAL DEVOLUCIONES', s.total1],
    [],
    ['DESCUENTOS'],
    ['Código/Nombre', 'Importe'],
    ...(s.clientes||[]).map(c => [c.codigo, c.importe]),
    ['', 'TOTAL DESCUENTOS', s.total2],
    [],
    ['TOTAL SEMANAL', '', s.totalSemanal]
  ];
  const ws = XLSX.utils.aoa_to_sheet(data);
  XLSX.utils.book_append_sheet(wb, ws, 'Semana ' + formatFecha(s.fecha));
  XLSX.writeFile(wb, `semana_${s.fecha}.xlsx`);
  showToast('📊 Excel descargado');
}

// ========== EDITAR SEMANA ==========
function abrirEditar(idx) {
  const sorted = window._sortedHist;
  if (!sorted || !sorted[idx]) return;
  const s = JSON.parse(JSON.stringify(sorted[idx])); // copia profunda

  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:2000;display:flex;align-items:flex-start;justify-content:center;padding:16px;overflow-y:auto;';

  const buildRows1 = (items) => (items||[]).map((d,i) => `
    <tr id="edit1_row_${i}">
      <td><input class="cell" value="${d.codigo||''}" oninput="editTemp.dieteticas[${i}].codigo=this.value" placeholder="Código"></td>
      <td><input class="cell" value="${d.descripcion||''}" oninput="editTemp.dieteticas[${i}].descripcion=this.value" placeholder="Descripción"></td>
      <td><input class="cell monto" type="number" value="${d.importe||''}" oninput="editTemp.dieteticas[${i}].importe=parseFloat(this.value)||0;recalcEdit()" placeholder="0"></td>
      <td><button class="btn-del" onclick="eliminarFilaEdit(1,${i})">✕</button></td>
    </tr>`).join('');

  const buildRows2 = (items) => (items||[]).map((c,i) => `
    <tr id="edit2_row_${i}">
      <td><input class="cell ${c.fixed?'fixed-name':''}" value="${c.codigo||''}" ${c.fixed?'readonly':''} oninput="editTemp.clientes[${i}].codigo=this.value" placeholder="Código"></td>
      <td><input class="cell monto" type="number" value="${c.importe||''}" oninput="editTemp.clientes[${i}].importe=parseFloat(this.value)||0;recalcEdit()" placeholder="0"></td>
      <td>${c.fixed?'':'<button class="btn-del" onclick="eliminarFilaEdit(2,'+i+')">✕</button>'}</td>
    </tr>`).join('');

  window.editTemp = JSON.parse(JSON.stringify(s));

  overlay.innerHTML = `
    <div style="background:white;border-radius:16px;padding:20px;max-width:500px;width:100%;box-shadow:0 8px 40px rgba(0,0,0,0.3);font-family:'Sora',sans-serif;margin:auto;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <h3 style="color:var(--verde);font-size:1rem;">✏️ Editar semana del ${formatFecha(s.fecha)}</h3>
        <button onclick="this.closest('[style*=fixed]').remove()" style="background:none;border:none;font-size:1.3rem;cursor:pointer;color:#888;">✕</button>
      </div>

      <strong style="color:var(--verde);font-size:0.8rem;">↩️ DEVOLUCIONES</strong>
      <table style="width:100%;margin:6px 0 4px;" id="editTable1">
        <thead><tr><th style="width:28%">Código</th><th style="width:42%">Descripción</th><th style="width:25%">Importe</th><th style="width:5%"></th></tr></thead>
        <tbody id="editTbody1">${buildRows1(s.dieteticas)}</tbody>
      </table>
      <button class="btn-add" onclick="agregarFilaEdit(1)" style="margin-bottom:12px;">+ Agregar devolución</button>

      <strong style="color:var(--verde);font-size:0.8rem;">🏷️ DESCUENTOS</strong>
      <table style="width:100%;margin:6px 0 4px;" id="editTable2">
        <thead><tr><th style="width:45%">Código</th><th style="width:50%">Importe</th><th style="width:5%"></th></tr></thead>
        <tbody id="editTbody2">${buildRows2(s.clientes)}</tbody>
      </table>
      <button class="btn-add" onclick="agregarFilaEdit(2)" style="margin-bottom:12px;">+ Agregar descuento</button>

      <div style="background:var(--verde);color:white;border-radius:8px;padding:10px 14px;display:flex;justify-content:space-between;margin-bottom:14px;">
        <strong>TOTAL SEMANAL</strong>
        <strong id="editTotal" style="font-family:monospace;">${formatMoney((s.total1||0)+(s.total2||0))}</strong>
      </div>

      <div style="display:flex;gap:10px;">
        <button onclick="this.closest('[style*=fixed]').remove()" style="flex:1;padding:11px;border:2px solid var(--border);background:white;border-radius:10px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;cursor:pointer;color:var(--text-mid);">Cancelar</button>
        <button onclick="guardarEdicion('${s._fbKey||''}','${s.guardadoEn||''}')" style="flex:1;padding:11px;background:var(--verde);border:none;border-radius:10px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;cursor:pointer;color:white;">💾 Guardar cambios</button>
      </div>
    </div>
  `;
  document.body.appendChild(overlay);
}

function recalcEdit() {
  const t1 = (window.editTemp.dieteticas||[]).reduce((s,r) => s+(parseFloat(r.importe)||0), 0);
  const t2 = (window.editTemp.clientes||[]).reduce((s,r) => s+(parseFloat(r.importe)||0), 0);
  const el = document.getElementById('editTotal');
  if (el) el.textContent = formatMoney(t1+t2);
}

function eliminarFilaEdit(tabla, idx) {
  if (tabla === 1) {
    window.editTemp.dieteticas.splice(idx, 1);
    document.getElementById('editTbody1').innerHTML = window.editTemp.dieteticas.map((d,i) => `
      <tr><td><input class="cell" value="${d.codigo||''}" oninput="editTemp.dieteticas[${i}].codigo=this.value" placeholder="Código"></td>
      <td><input class="cell" value="${d.descripcion||''}" oninput="editTemp.dieteticas[${i}].descripcion=this.value" placeholder="Descripción"></td>
      <td><input class="cell monto" type="number" value="${d.importe||''}" oninput="editTemp.dieteticas[${i}].importe=parseFloat(this.value)||0;recalcEdit()" placeholder="0"></td>
      <td><button class="btn-del" onclick="eliminarFilaEdit(1,${i})">✕</button></td></tr>`).join('');
  } else {
    const r = window.editTemp.clientes[idx];
    if (r && r.fixed) { showToast('No se puede eliminar un cliente fijo', true); return; }
    window.editTemp.clientes.splice(idx, 1);
    document.getElementById('editTbody2').innerHTML = window.editTemp.clientes.map((c,i) => `
      <tr><td><input class="cell ${c.fixed?'fixed-name':''}" value="${c.codigo||''}" ${c.fixed?'readonly':''} oninput="editTemp.clientes[${i}].codigo=this.value" placeholder="Código"></td>
      <td><input class="cell monto" type="number" value="${c.importe||''}" oninput="editTemp.clientes[${i}].importe=parseFloat(this.value)||0;recalcEdit()" placeholder="0"></td>
      <td>${c.fixed?'':'<button class="btn-del" onclick="eliminarFilaEdit(2,'+i+')">✕</button>'}</td></tr>`).join('');
  }
  recalcEdit();
}

function agregarFilaEdit(tabla) {
  if (tabla === 1) {
    window.editTemp.dieteticas.push({ codigo:'', descripcion:'galletas rotas', importe:0 });
    const i = window.editTemp.dieteticas.length - 1;
    const tr = document.createElement('tr');
    tr.innerHTML = `<td><input class="cell" value="" oninput="editTemp.dieteticas[${i}].codigo=this.value" placeholder="Código"></td>
      <td><input class="cell" value="galletas rotas" oninput="editTemp.dieteticas[${i}].descripcion=this.value" placeholder="Descripción"></td>
      <td><input class="cell monto" type="number" value="" oninput="editTemp.dieteticas[${i}].importe=parseFloat(this.value)||0;recalcEdit()" placeholder="0"></td>
      <td><button class="btn-del" onclick="eliminarFilaEdit(1,${i})">✕</button></td>`;
    document.getElementById('editTbody1').appendChild(tr);
  } else {
    window.editTemp.clientes.push({ codigo:'', importe:0, fixed:false });
    const i = window.editTemp.clientes.length - 1;
    const tr = document.createElement('tr');
    tr.innerHTML = `<td><input class="cell" value="" oninput="editTemp.clientes[${i}].codigo=this.value" placeholder="Código"></td>
      <td><input class="cell monto" type="number" value="" oninput="editTemp.clientes[${i}].importe=parseFloat(this.value)||0;recalcEdit()" placeholder="0"></td>
      <td><button class="btn-del" onclick="eliminarFilaEdit(2,${i})">✕</button></td>`;
    document.getElementById('editTbody2').appendChild(tr);
  }
}

async function guardarEdicion(fbKey, guardadoEn) {
  const t1 = (window.editTemp.dieteticas||[]).reduce((s,r) => s+(parseFloat(r.importe)||0), 0);
  const t2 = (window.editTemp.clientes||[]).reduce((s,r) => s+(parseFloat(r.importe)||0), 0);
  window.editTemp.total1 = t1;
  window.editTemp.total2 = t2;
  window.editTemp.totalSemanal = t1 + t2;

  if (window._firebaseOk && fbKey && window._db && window._dbRef && window._dbSet) {
    try {
      const itemRef = window._dbRef(window._db, 'historial/' + fbKey);
      const toSave = {...window.editTemp};
      delete toSave._fbKey;
      await window._dbSet(itemRef, toSave);
      showToast('✅ Cambios guardados en la nube');
    } catch(e) {
      showToast('Error al guardar', true); return;
    }
  } else {
    // Local
    let hist = JSON.parse(localStorage.getItem('historial_dietetica') || '[]');
    const idx = hist.findIndex(h => h.guardadoEn === guardadoEn);
    if (idx >= 0) hist[idx] = window.editTemp;
    localStorage.setItem('historial_dietetica', JSON.stringify(hist));
    window._historial = hist;
    renderHistorial(hist);
    showToast('✅ Cambios guardados');
  }
  // Cerrar modal
  const overlays = document.querySelectorAll('[style*="position:fixed"]');
  overlays.forEach(o => { if (o.style.zIndex == 2000) o.remove(); });
}

// ========== LIMPIAR ==========
function limpiarFormulario() {
  if (!confirm('¿Limpiar el formulario actual?')) return;
  setMondayDate();
  initRows1();
  initRows2();
  recalc();
}

// ========== BORRAR SEMANA ==========
function confirmarBorrar(idx) {
  const hist = window._historial || [];
  const sorted = [...hist].sort((a, b) => b.fecha.localeCompare(a.fecha));
  const s = sorted[idx];
  if (!s) return;

  // Crear modal
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;display:flex;align-items:center;justify-content:center;padding:20px;';

  overlay.innerHTML = `
    <div style="background:white;border-radius:16px;padding:24px;max-width:320px;width:100%;box-shadow:0 8px 40px rgba(0,0,0,0.3);font-family:'Sora',sans-serif;">
      <div style="text-align:center;margin-bottom:16px;">
        <div style="font-size:2.5rem;margin-bottom:8px;">⚠️</div>
        <h3 style="color:#1a2e22;font-size:1.1rem;margin-bottom:8px;">¿Borrar esta semana?</h3>
        <p style="color:#4a6b55;font-size:0.9rem;line-height:1.4;">
          <strong>📅 ${formatFecha(s.fecha)}</strong><br>
          Total: <strong style="font-family:monospace">${formatMoney(s.totalSemanal || 0)}</strong>
        </p>
        <p style="color:#e74c3c;font-size:0.8rem;margin-top:10px;">Esta acción no se puede deshacer.</p>
      </div>
      <div style="display:flex;gap:10px;">
        <button id="btnCancelarBorrar" style="flex:1;padding:11px;border:2px solid #c8e6d4;background:white;border-radius:10px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;cursor:pointer;color:#4a6b55;">Cancelar</button>
        <button id="btnConfirmarBorrar" style="flex:1;padding:11px;background:#e74c3c;border:none;border-radius:10px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;cursor:pointer;color:white;">Sí, borrar</button>
      </div>
    </div>
  `;

  document.body.appendChild(overlay);

  document.getElementById('btnCancelarBorrar').onclick = () => document.body.removeChild(overlay);
  overlay.onclick = (e) => { if (e.target === overlay) document.body.removeChild(overlay); };

  document.getElementById('btnConfirmarBorrar').onclick = async () => {
    document.body.removeChild(overlay);
    await borrarSemana(s);
  };
}

async function borrarSemana(s) {
  // Firebase
  if (window._firebaseOk && window._borrarSemanaFirebase && s._fbKey) {
    try {
      await window._borrarSemanaFirebase(s._fbKey);
      showToast('🗑️ Semana borrada');
      return;
    } catch(e) {
      showToast('Error al borrar en la nube', true);
    }
  }
  // Local
  let hist = JSON.parse(localStorage.getItem('historial_dietetica') || '[]');
  hist = hist.filter(h => !(h.fecha === s.fecha && h.guardadoEn === s.guardadoEn));
  localStorage.setItem('historial_dietetica', JSON.stringify(hist));
  window._historial = hist;
  renderHistorial(hist);
  showToast('🗑️ Semana borrada');
}


function showToast(msg, error = false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast' + (error ? ' error' : '') + ' show';
  setTimeout(() => t.classList.remove('show'), 3000);
}
</script>

